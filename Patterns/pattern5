class Solution {
public:
    void pattern13(int n) {
     int num = 1 ;
     // outer loop 
     for ( int i =1 ; i <= n ; i++ ){
        // inner loop 
        for ( int j = 1 ; j <= i ; j++ ){
            cout << num << " ";
            // conditions 
            num = num+1;
        }
       cout << endl;
    }
   }
};